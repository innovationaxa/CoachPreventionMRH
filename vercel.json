{
  "version": 2,
  "name": "coach-prevention-mrh",
  "builds": [{ "src": "**/*", "use": "@vercel/static" }],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/$1" }]
}
